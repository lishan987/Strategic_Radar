{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "issue", "title", "published_at", "summary", "items", "update_notes"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "发布日期 YYYY-MM-DD"
      },
      "issue": {
        "type": "integer",
        "minimum": 1,
        "description": "期号"
      },
      "title": {
        "type": "string",
        "description": "报告标题"
      },
      "published_at": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "发布日期"
      },
      "summary": {
        "type": "string",
        "description": "本期核心洞察摘要"
      },
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["category", "source", "insight", "impact"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["政策类", "市场类", "产品类", "企业动态类"]
            },
            "source": {
              "type": "string",
              "description": "原始零碎信息"
            },
            "insight": {
              "type": "string",
              "description": "水面下洞察（含优先级）"
            },
            "impact": {
              "type": "object",
              "required": ["consumer", "operation", "compliance", "competition"],
              "properties": {
                "consumer": { "type": "string" },
                "operation": { "type": "string" },
                "compliance": { "type": "string" },
                "competition": { "type": "string" }
              }
            }
          }
        }
      },
      "update_notes": {
        "type": "string",
        "description": "本次更新说明"
      }
    }
  }
}
